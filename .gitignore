# ───────────── Dependencies (never commit) ─────────────
/node_modules/
/vendor/

# ───────────── Secrets / environment ─────────────
.env
.env.*
!.env.example
*.key
auth.json
/storage/oauth-*.key

# ───────────── Laravel storage (runtime data, logs, DB dumps, uploads) ─────────────
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/framework/testing/*
/storage/logs/*
/storage/db-backups/*
/storage/app/public/*
/storage/app/livewire-tmp/*
/bootstrap/cache/*.php

# ───────────── Build artifacts ─────────────
# (If your live/deploy host has NO Node.js, delete the next line so compiled
#  Vite assets get committed and you can deploy without running "npm run build".)
/public/build/
/public/hot
/public/storage

# ───────────── OS / editor / tooling junk ─────────────
__MACOSX/
.DS_Store
Thumbs.db
*.log
/.idea/
/.vscode/
/.fleet/
/.nova/
/.zed/
.phpunit.result.cache
npm-debug.log
yarn-error.log

# ───────────── Claude Code local state (not app code) ─────────────
/.claude/
